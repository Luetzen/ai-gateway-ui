{
  "name": "@luetzen/ai-gateway-ui",
  "version": "0.1.0",
  "description": "Vue 3 component library for AI Gateway settings UI — provider status, quick test, and configuration panel",
  "type": "module",
  "main": "./dist/ai-gateway-ui.umd.cjs",
  "module": "./dist/ai-gateway-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ai-gateway-ui.js",
      "require": "./dist/ai-gateway-ui.umd.cjs"
    },
    "./style.css": "./dist/ai-gateway-ui.css",
    "./theme/default.css": "./dist/theme-default.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp src/theme-default.css dist/theme-default.css",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": ">=3.4.0",
    "pinia": ">=2.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "^5.4.0",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.6",
    "vue-tsc": "^2.1.6",
    "pinia": "^2.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Luetzen/ai-gateway-ui.git"
  },
  "license": "MIT",
  "author": "Luetzen",
  "keywords": [
    "vue",
    "vue3",
    "ai",
    "ai-gateway",
    "settings",
    "component-library",
    "pinia"
  ]
}
